---
import { ExternalLink } from "lucide-react";
import corseImg from "../images/corse.png";
import finistereImg from "../images/finister.png";
import heraultImg from "../images/herault.png";
import megeveImg from "../images/savoie_megeve.png";

const otherSites = [
    {
        title: "Maison d’Hôte en Corse",
        category: "CHARME & AUTHENTICITÉ",
        description:
            "Une immersion confidentielle dans le maquis. Pierres ancestrales et hospitalité traditionnelle au cœur de l'île.",
        image: corseImg,
        link: "https://cassetta92-lumio.xiri-conciergerie.fr/",
    },
    {
        title: "Mobilhome au Finistère",
        category: "ÉVASION IODÉE",
        description:
            "Le confort moderne face à la puissance de l'Atlantique. Une escale nature sur les côtes sauvages de Bretagne.",
        image: finistereImg,
        link: "https://finistere-mobilhome.xiri-conciergerie.fr/",
    },
    {
        title: "Maison d’Hôte au Hérault",
        category: "DOUCEUR OCCITANE",
        description:
            "L'élégance du Sud entre vignes et oliviers. Une parenthèse de sérénité dans l'arrière-pays héraultais.",
        image: heraultImg,
        link: "https://herault-xiri.pages.dev/",
    },
    {
        title: "Studio à Megève",
        category: "ÉVASION ALPINE",
        description:
            "L'élégance du bois et le confort moderne au pied des pistes. Une escale de luxe pour vos séjours en altitude.",
        image: megeveImg,
        link: "#",
    },
];
---

<section class="py-12 md:py-16 relative overflow-hidden">
    <div
        class="absolute top-1/2 left-0 -translate-y-1/2 opacity-[0.01] pointer-events-none w-full text-center"
    >
        <span
            class="text-[300px] font-serif font-black tracking-tighter text-xiri-navy uppercase"
        >
            L'UNIVERS
        </span>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="text-center mb-16 md:mb-20 space-y-6">
            <span
                class="text-xiri-gold text-[10px] font-black uppercase tracking-[0.8em] block"
                >Nos Autres Destinations</span
            >
            <h2
                class="text-3xl md:text-4xl font-serif text-xiri-navy leading-tight"
            >
                Explorez notre <br /><span class="font-light"
                    >Collection Privée</span
                >.
            </h2>
            <div class="w-24 h-[1px] bg-xiri-gold mx-auto mt-12"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16 lg:gap-x-12">
            {
                otherSites.map((site) => (
                    <a
                        href={site.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group block space-y-10 no-underline"
                    >
                        <div class="relative aspect-[4/3] overflow-hidden p-[8px] bg-white shadow-lg transition-transform duration-700 group-hover:-translate-y-2">
                            <img
                                src={site.image.src}
                                alt={site.title}
                                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 grayscale-[0.3] group-hover:grayscale-0"
                            />
                            <div class="absolute inset-0 bg-xiri-navy/5 group-hover:bg-transparent transition-colors duration-500" />

                            <div class="absolute bottom-6 left-6 right-6">
                                <div class="bg-white/90 backdrop-blur-sm p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-700">
                                    <div class="flex justify-between items-center">
                                        <span class="text-[9px] font-black uppercase tracking-widest text-xiri-gold">
                                            Accéder au site
                                        </span>
                                        <ExternalLink
                                            size={14}
                                            class="text-xiri-navy"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-4 text-center md:text-left px-4 md:px-0">
                            <span class="text-[9px] font-bold text-xiri-gold uppercase tracking-[0.4em]">
                                {site.category}
                            </span>
                            <h3 class="text-3xl font-serif text-xiri-navy group-hover:text-xiri-gold transition-colors duration-500">
                                {site.title}
                            </h3>
                            <p class="text-[14px] text-[#000000] leading-relaxed font-medium max-w-xs mx-auto md:mx-0">
                                "{site.description}"
                            </p>

                            <div class="pt-6">
                                <div class="inline-flex items-center gap-4 text-[10px] font-black uppercase tracking-[0.3em] text-xiri-navy">
                                    Découvrir
                                    <div class="w-12 h-[1px] bg-xiri-navy/10 group-hover:w-24 group-hover:bg-xiri-gold transition-all duration-700" />
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
