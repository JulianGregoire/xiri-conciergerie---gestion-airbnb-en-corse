---
import { Zap } from "lucide-react";
---

<section class="py-16 md:py-24 bg-xiri-navy relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-xiri-gold/10 rounded-full -translate-y-1/2 translate-x-1/2 blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-xiri-gold/5 rounded-full translate-y-1/2 -translate-x-1/2 blur-[80px]"></div>

    <div class="w-full relative z-10 px-6">
        <div class="flex flex-col items-center text-center space-y-8">
            <!-- Icon/Badge -->
            <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-5 py-2 rounded-full backdrop-blur-sm">
                <Zap size={14} className="text-xiri-gold fill-xiri-gold animate-pulse" />
                <span class="text-[9px] font-black uppercase tracking-[0.4em] text-white/80">Déploiement Ultra-Rapide</span>
            </div>

            <div class="space-y-4 max-w-3xl">
                <h2 class="text-3xl md:text-5xl lg:text-5xl font-serif text-white leading-[1.1] tracking-tight">
                    Opérationnel en <br />
                    <span class="text-xiri-gold font-light italic">15 jours</span>
                </h2>
                <p class="text-[15px] md:text-[17px] text-white/60 leading-relaxed font-medium max-w-xl mx-auto">
                    Vous décidez. On exécute. Votre bien génère des revenus sans effort.
                </p>
            </div>

            <div class="pt-6">
                <a
                    href="#contact"
                    class="group relative inline-flex items-center gap-6 bg-xiri-gold text-white px-8 py-4 text-[10px] uppercase tracking-[0.3em] font-black hover:bg-white hover:text-xiri-navy transition-all duration-700 rounded-xl no-underline shadow-xl shadow-xiri-gold/20"
                >
                    Démarrer maintenant
                    <div class="w-6 h-[1px] bg-white group-hover:bg-xiri-navy group-hover:w-12 transition-all duration-700"></div>
                </a>
            </div>
        </div>
    </div>
</section>
