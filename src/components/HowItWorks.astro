---
const steps = [
    {
        number: "01",
        title: "Estimation & Stratégie",
        description:
            "Analyse du bien, potentiel locatif, contraintes légales et objectifs de revenu.",
        reassurance: "Légalité garantie",
    },
    {
        number: "02",
        title: "Shooting & Mise en Ligne",
        description:
            "Photos, annonce optimisée, diffusion multi-canaux et stratégie de prix dynamique.",
        reassurance: "Visibilité pilotée",
    },
    {
        number: "03",
        title: "Gestion & Encaissement",
        description:
            "Accueil voyageurs, opérations terrain, maintenance et reporting mensuel transparent.",
        reassurance: "Délégation totale",
    },
];
---

<section
    id="how-it-works"
    class="py-16 md:py-24 lg:py-32 bg-[#1B2B44] relative overflow-hidden border-y border-white/5"
>
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-xiri-gold/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-[100px]"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="text-center mb-12 md:mb-16 space-y-3">
            <span
                class="text-xiri-gold text-[10px] font-black uppercase tracking-[0.25em]"
                >Comment Ça Marche ?</span
            >
            <h2
                class="text-[26px] md:text-[34px] lg:text-[40px] font-serif text-white leading-tight"
            >
                3 Étapes Simples
            </h2>
            <p
                class="text-[15px] text-white/60 max-w-2xl mx-auto font-medium leading-relaxed"
            >
                Un cadre clair, des responsabilités définies, une exécution
                mesurable.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
            {
                steps.map((step) => (
                    <div class="bg-white/5 border border-white/10 p-6 md:p-8 rounded-[24px] backdrop-blur-sm group hover:border-xiri-gold/30 transition-all duration-500">
                        <div class="mb-6 flex items-center">
                            <span class="text-5xl font-serif text-xiri-gold opacity-20 group-hover:opacity-100 transition-opacity duration-700 leading-none">
                                {step.number}
                            </span>
                        </div>

                        <div class="space-y-6">
                            <h3 class="text-[24px] font-serif text-white tracking-wide">
                                {step.title}
                            </h3>
                            <p class="text-[15px] text-white/60 leading-relaxed font-medium">
                                {step.description}
                            </p>
                            <div class="flex items-center gap-3 pt-2">
                                <div class="w-8 h-[1px] bg-xiri-gold"></div>
                                <span class="text-[10px] uppercase tracking-[0.2em] font-black text-xiri-gold">
                                    {step.reassurance}
                                </span>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
