import { Phone } from "lucide-react";
import ChatBot from "./ChatBot";
---

<a
    href="tel:+33782312206"
    class="fixed bottom-6 right-6 z-50 flex items-center justify-center gap-3 bg-xiri-navy text-white p-4 md:px-6 md:py-4 rounded-full shadow-2xl hover:bg-xiri-gold hover:scale-105 transition-all duration-300 no-underline group border border-white/10"
    aria-label="Nous appeler"
>
    <!-- Icon part (always visible) -->
    <div class="flex items-center justify-center relative w-5 h-5">
        <div class="absolute inset-0 bg-white/20 rounded-full animate-ping opacity-75"></div>
        <Phone size={20} className="relative z-10" />
    </div>

    <!-- Text part (visible on md screens and up) -->
    <span class="hidden md:block text-[13px] font-bold tracking-[0.15em] whitespace-nowrap">
        07 82 31 22 06
    </span>
</a>

<ChatBot client:load />
