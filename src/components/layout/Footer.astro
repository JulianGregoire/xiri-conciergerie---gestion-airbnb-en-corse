---
import { regions } from '../../data/regions';
const year = new Date().getFullYear();


---

<footer
    class="bg-xiri-navy py-16 md:py-24 px-6 lg:px-12 border-t border-white/5 relative"
>
    <div
        class="absolute bottom-0 left-0 w-full h-[5px] bg-gradient-to-r from-xiri-navy via-xiri-gold to-xiri-navy"
    >
    </div>

    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-16 mb-16 md:mb-20">
            <div class="lg:col-span-3 space-y-8">
                <a href="/" class="flex flex-col text-left no-underline group">
                    <span
                        class="text-xl font-serif font-medium tracking-[0.1em] text-white group-hover:text-xiri-gold transition-colors"
                        >XIRI CONCIERGERIE</span
                    >
                    <span
                        class="text-[10px] uppercase tracking-[0.5em] font-bold text-xiri-gold"
                        >Hérault, Savoie, Corse, Finistère Sud</span
                    >
                </a>
                <p
                    class="text-[13px] text-white/60 leading-loose font-light max-w-xs"
                >
                    "Redéfinir l'hospitalité à travers une gestion
                    immobilière personnalisée et un service de conciergerie
                    irréprochable."
                </p>
                <div class="flex space-x-6">
                    <a
                        href="#"
                        class="text-white hover:text-xiri-gold transition-colors no-underline"
                    >
                        <span
                            class="text-[11px] font-bold tracking-widest uppercase border-b border-white/10 pb-1"
                            >Instagram</span
                        >
                    </a>
                    <a
                        href="#"
                        class="text-white hover:text-xiri-gold transition-colors no-underline"
                    >
                        <span
                            class="text-[11px] font-bold tracking-widest uppercase border-b border-white/10 pb-1"
                            >LinkedIn</span
                        >
                    </a>
                    <a
                        href="#"
                        class="text-white hover:text-xiri-gold transition-colors no-underline"
                    >
                        <span
                            class="text-[11px] font-bold tracking-widest uppercase border-b border-white/10 pb-1"
                            >Facebook</span
                        >
                    </a>
                </div>
            </div>

            <div class="lg:col-span-9 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12">
                <div class="space-y-8">
                    <h5
                        class="text-[10px] font-bold tracking-[0.3em] text-xiri-gold uppercase"
                    >
                        Navigation
                    </h5>
                    <ul
                        class="text-[11px] text-white/60 space-y-4 uppercase tracking-[0.2em] font-medium list-none p-0"
                    >
                        <li>
                            <a
                                href="/"
                                class="hover:text-white transition-colors uppercase tracking-[0.2em] text-white/60 no-underline"
                            >
                                Accueil
                            </a>
                        </li>
                        <li>
                            <a
                                href="/a-propos"
                                class="hover:text-white transition-colors uppercase tracking-[0.2em] text-white/60 no-underline"
                            >
                                Notre Vision
                            </a>
                        </li>
                        <li>
                            <a
                                href="/blog"
                                class="hover:text-white transition-colors uppercase tracking-[0.2em] text-white/60 no-underline"
                            >
                                Blog
                            </a>
                        </li>
                        <li>
                            <a
                                href="/#contact"
                                class="hover:text-white transition-colors uppercase tracking-[0.2em] text-white/60 no-underline"
                            >
                                Contact
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="sm:col-span-2 space-y-8" id="conciergeries">
                    <h5
                        class="text-[10px] font-bold tracking-[0.3em] text-xiri-gold uppercase"
                    >
                        Nos Conciergeries
                    </h5>
                    <div class="grid grid-cols-2 gap-x-12 gap-y-12">
                        {
                            regions.map((region) => (
                                <div class="space-y-4">
                                    <a href={`/regions/${region.slug}`} class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30 border-b border-white/5 pb-2 block hover:text-xiri-gold transition-colors no-underline">
                                        {region.name}
                                    </a>
                                    <ul class="text-[11px] space-y-3 list-none p-0">
                                        {region.villes.map((ville) => (
                                            <li>
                                                <a
                                                    href={ville.href}
                                                    class="hover:text-white transition-colors uppercase tracking-[0.15em] text-white/60 no-underline"
                                                >
                                                    {ville.name}
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="space-y-8">
                    <h5
                        class="text-[10px] font-bold tracking-[0.3em] text-xiri-gold uppercase"
                    >
                        L'Agence
                    </h5>
                    <div
                        class="text-[11px] text-white/60 space-y-4 uppercase tracking-[0.2em] font-light leading-relaxed"
                    >
                        <p>
                            XIRI-HOUSE<br />
                            9 impasse Lucie aubrac<br />
                            34440 Nissan lez Enserune
                        </p>
                        <p>Ouvert du Lundi au Samedi<br />de 10h à 20h</p>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6"
        >
            <p class="text-[9px] uppercase tracking-[0.4em] text-white/30">
                © {year} XIRI CONCIERGERIE. TOUS DROITS RÉSERVÉS.
            </p>
            <div class="flex space-x-12">
                <a
                    href="/mentions-legales"
                    class="text-[9px] uppercase tracking-[0.4em] text-white/30 hover:text-white transition-colors no-underline"
                    >Mentions Légales</a
                >
                <a
                    href="/confidentialite"
                    class="text-[9px] uppercase tracking-[0.4em] text-white/30 hover:text-white transition-colors no-underline"
                    >Confidentialité</a
                >
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center space-y-2">
            <h6 class="text-[9px] font-bold tracking-[0.3em] text-xiri-gold uppercase">
                Services aux propriétaires :
            </h6>
            <p class="text-[9px] uppercase tracking-[0.2em] text-white/30 max-w-4xl mx-auto leading-relaxed">
                La conciergerie Xiri-house n'étant pas titulaire de la carte professionnelle visée par la loi du 02/01/1970 n'effectue aucun maniement de fonds, paiement de nos prestations sur facture.
                <span class="block mt-1">Nous agissons en tant que co hôte sur les diverses plateformes.</span>
            </p>
        </div>
    </div>
</footer>
