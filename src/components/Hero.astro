---
import HeroSlider from "./HeroSlider";
---

<section
    id="home"
    class="relative pt-20 pb-10 md:pt-24 md:pb-12 lg:pt-32 lg:pb-16 bg-white overflow-hidden border-b border-xiri-navy/5"
>
    <div class="max-w-7xl mx-auto px-6">
        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10 items-center"
        >
            <div class="lg:col-span-7 space-y-6 z-10">
                <span
                    class="text-[11px] font-bold text-xiri-gold tracking-[0.28em] uppercase block"
                >
                    Conciergerie premium en Corse
                </span>

                <h1
                    class="text-[32px] sm:text-[40px] lg:text-[46px] font-serif text-xiri-navy leading-[1.15]"
                >
                    Confiez votre bien. Revenus optimisés, gestion 100%
                    déléguée.
                </h1>

                <p
                    class="text-[16px] text-xiri-navy/80 leading-relaxed max-w-2xl font-medium"
                >
                    Xiri pilote l'annonce, la sélection voyageurs,
                    l'opérationnel terrain et le reporting mensuel. Vous gardez
                    la visibilité financière, nous gérons l'exécution.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div
                        class="border border-xiri-navy/10 bg-xiri-bg/30 px-4 py-3 rounded-xl"
                    >
                        <p
                            class="text-[10px] uppercase tracking-[0.18em] text-xiri-navy/50 font-bold"
                        >
                            Performance
                        </p>
                        <p class="text-[20px] font-semibold text-xiri-navy">
                            +27% revenu moyen
                        </p>
                    </div>
                    <div
                        class="border border-xiri-navy/10 bg-xiri-bg/30 px-4 py-3 rounded-xl"
                    >
                        <p
                            class="text-[10px] uppercase tracking-[0.18em] text-xiri-navy/50 font-bold"
                        >
                            Réactivité
                        </p>
                        <p class="text-[20px] font-semibold text-xiri-navy">
                            Réponse &lt; 24h
                        </p>
                    </div>
                    <div
                        class="border border-xiri-navy/10 bg-xiri-bg/30 px-4 py-3 rounded-xl"
                    >
                        <p
                            class="text-[10px] uppercase tracking-[0.18em] text-xiri-navy/50 font-bold"
                        >
                            Transparence
                        </p>
                        <p class="text-[20px] font-semibold text-xiri-navy">
                            Reporting mensuel
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row gap-3 pt-1">
                    <a
                        href="#contact"
                        class="bg-xiri-navy text-white px-7 py-4 text-[11px] uppercase tracking-[0.2em] font-extrabold hover:bg-xiri-gold transition-all duration-300 rounded-xl no-underline text-center"
                    >
                        Estimer ma rentabilité
                    </a>
                    <a
                        href="#services"
                        class="bg-white text-xiri-navy border border-xiri-navy/20 px-7 py-4 text-[11px] uppercase tracking-[0.2em] font-extrabold hover:bg-xiri-navy hover:text-white transition-all duration-300 rounded-xl no-underline text-center"
                    >
                        Voir les services
                    </a>
                </div>
            </div>

            <div
                class="lg:col-span-5 relative h-[280px] sm:h-[340px] lg:h-[420px]"
            >
                <HeroSlider client:load />
            </div>
        </div>
    </div>
</section>
