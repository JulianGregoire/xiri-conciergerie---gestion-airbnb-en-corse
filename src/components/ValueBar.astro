---

---

<section
    class="bg-white py-10 md:py-12 relative z-20 border-b border-xiri-navy/5"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="mb-8 md:mb-10">
            <h2
                class="text-[28px] md:text-[34px] font-serif text-xiri-navy leading-tight"
            >
                Pourquoi nous confier votre bien ?
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">

            <div
                class="flex gap-4 border border-xiri-navy/10 bg-xiri-bg/25 p-5 rounded-2xl"
            >
                <div
                    class="flex-shrink-0 w-11 h-11 bg-white flex items-center justify-center text-xiri-gold shadow-sm rounded-xl"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="lucide lucide-user-check"
                        ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                        ></path><circle cx="9" cy="7" r="4"></circle><polyline
                            points="16 11 18 13 22 9"></polyline></svg
                    >
                </div>
                <div class="space-y-1">
                    <h3
                        class="text-[20px] font-serif text-xiri-navy leading-snug"
                    >
                        Gagnez en liberté
                    </h3>
                    <p
                        class="text-[14px] text-xiri-navy/80 leading-relaxed font-medium"
                    >
                        De la remise des clés au ménage pro, une gestion 100% déléguée.
                    </p>
                </div>
            </div>

            <div
                class="flex gap-4 border border-xiri-navy/10 bg-xiri-bg/25 p-5 rounded-2xl"
            >
                <div
                    class="flex-shrink-0 w-11 h-11 bg-white flex items-center justify-center text-xiri-gold shadow-sm rounded-xl"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="lucide lucide-shield-check"
                        ><path
                            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                        ></path><path d="m9 12 2 2 4-4"></path></svg
                    >
                </div>
                <div class="space-y-1">
                    <h3
                        class="text-[20px] font-serif text-xiri-navy leading-snug"
                    >
                        Louez en toute sérénité
                    </h3>
                    <p
                        class="text-[14px] text-xiri-navy/80 leading-relaxed font-medium"
                    >
                        Voyageurs filtrés, cautions gérées et revenus suivis en temps réel.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
