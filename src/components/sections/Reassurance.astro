---
import { Image } from "astro:assets";
import julianPhoto from "../../assets/images/team/julian-profile.webp";
import didierPhoto from "../../assets/images/team/didier-profile.webp";
import mariePhoto from "../../assets/images/team/marie-profile.webp";
import pierrePhoto from "../../assets/images/team/Pierre-profile.webp";
---

<section class="py-8 md:py-10 bg-xiri-bg/60 border-y border-xiri-navy/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-12">
            <!-- Accent vertical bar -->
            <div class="hidden md:block w-1 h-20 bg-gradient-to-b from-xiri-gold to-xiri-gold/20 rounded-full flex-shrink-0"></div>

            <div class="flex flex-col gap-2 md:gap-3">
                <h2 class="text-[20px] md:text-[24px] font-serif text-xiri-navy leading-snug">
                    Xiri, c'est avant tout <span class="text-xiri-gold">notre équipe.</span>
                </h2>
                <p class="text-[14px] md:text-[15px] text-xiri-navy/70 font-medium leading-relaxed max-w-2xl">
                    Des gens du coin, implantés en Hérault, Savoie, Corse et Finistère Sud. Une vraie personne au bout du fil que vous pouvez appeler, rencontrer, et qui connaît votre bien.
                </p>
            </div>

            <!-- Team avatars -->
            <div class="flex items-center md:ml-auto md:flex-shrink-0">
                <Image
                    src={julianPhoto}
                    alt="Julian, équipe Xiri"
                    width={72}
                    height={72}
                    class="w-[72px] h-[72px] rounded-full object-cover ring-2 ring-xiri-gold"
                />
                <Image
                    src={didierPhoto}
                    alt="Didier, équipe Xiri"
                    width={72}
                    height={72}
                    class="w-[72px] h-[72px] rounded-full object-cover ring-2 ring-xiri-gold -ml-3"
                />
                <Image
                    src={mariePhoto}
                    alt="Marie, équipe Xiri"
                    width={72}
                    height={72}
                    class="w-[72px] h-[72px] rounded-full object-cover ring-2 ring-xiri-gold -ml-3"
                />
                <Image
                    src={pierrePhoto}
                    alt="Pierre, équipe Xiri"
                    width={72}
                    height={72}
                    class="w-[72px] h-[72px] rounded-full object-cover ring-2 ring-xiri-gold -ml-3"
                />
            </div>
        </div>
    </div>
</section>
