---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const entries = await getCollection("blog", ({ data }) => !data.draft);
const articles = entries
    .map((e) => ({ id: e.id, ...e.data }))
    .sort((a, b) => b.sortDate.getTime() - a.sortDate.getTime())
    .slice(0, 3);
---

<section class="py-12 md:py-16 lg:py-20 relative overflow-hidden">
    <div
        class="absolute top-0 right-0 w-1/2 h-full bg-[#F0F7FA]/20 -z-0 rounded-l-[100px] hidden lg:block"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="mb-16 md:mb-20 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="max-w-xl">
                <span
                    class="text-xiri-gold text-[9px] font-bold uppercase tracking-[0.6em] mb-4 block"
                    >Blog & Insights</span
                >
                <h2
                    class="text-4xl md:text-6xl font-serif text-xiri-navy leading-tight mb-6"
                >
                    Notre <span class="text-xiri-gold italic font-light"
                        >Expertise</span
                    >
                </h2>
                <p
                    class="text-[16px] text-[#0a0a0a] leading-relaxed font-medium"
                >
                    Fiscalité, réglementation, stratégie — tout ce qu'il faut savoir pour louer mieux.
                </p>
            </div>

            <a
                href="/blog"
                class="inline-flex items-center gap-3 text-xiri-navy font-bold uppercase tracking-[0.2em] text-[11px] hover:text-xiri-gold transition-colors border-b-2 border-xiri-gold pb-1 w-fit"
            >
                Voir tous les articles
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
            {
                articles.map((article) => (
                    <a href={`/blog/${article.id}`} class="group no-underline block">
                        <div class="relative h-[300px] mb-8 overflow-hidden p-[10px] bg-white shadow-lg transition-transform duration-700 group-hover:-translate-y-3">
                            {typeof article.heroImage === 'string' ? (
                                <img
                                    src={article.heroImage}
                                    alt={article.title}
                                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                                />
                            ) : (
                                <Image
                                    src={article.heroImage}
                                    alt={article.title}
                                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                                />
                            )}
                            <div class="absolute inset-0 bg-xiri-navy/5 group-hover:bg-transparent transition-colors duration-500" />
                            <div class="absolute top-6 left-6">
                                <span class="bg-white/95 backdrop-blur-sm px-4 py-1.5 shadow-sm text-[9px] font-black uppercase tracking-widest text-xiri-navy">
                                    {article.category}
                                </span>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div class="flex items-center gap-4 text-[9px] text-xiri-navy/40 font-bold uppercase tracking-widest">
                                <span>{article.date}</span>
                                <span class="w-1 h-1 bg-xiri-gold rounded-full" />
                                <span>{article.readTime} LECTURE</span>
                            </div>
                            <h3 class="text-xl font-serif text-xiri-navy tracking-wide leading-snug group-hover:text-xiri-gold transition-colors">
                                {article.title}
                            </h3>
                            <p class="text-[14px] text-xiri-navy/70 leading-relaxed font-medium line-clamp-2">
                                {article.excerpt}
                            </p>
                            <div class="pt-4 overflow-hidden">
                                <div class="h-[1px] w-12 bg-xiri-gold group-hover:w-full transition-all duration-700" />
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
