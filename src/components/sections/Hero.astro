---
import HeroSlider from "../ui/HeroSlider";
import { Check, Star } from "lucide-react";

const strongPoints = [
    "Zéro gestion — on s'occupe de tout",
    "Revenus optimisés quotidiennement",
    "Ménage & entretien",
    "Suivi financier en temps réel",
];
---

<section
    id="home"
    class="relative pt-24 pb-12 md:pt-32 md:pb-20 lg:pt-40 lg:pb-24 overflow-hidden border-b border-xiri-navy/5"
>
    <div class="max-w-7xl mx-auto px-6">
        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center"
        >
            <div class="lg:col-span-7 space-y-8 z-10">
                <div class="space-y-6">

                    <!-- Design Element: Gold Wave -->
                    <svg
                        class="text-xiri-gold w-20 h-2 opacity-80 overflow-visible"
                        viewBox="0 0 100 20"
                        preserveAspectRatio="none"
                    >
                        <path
                            class="animate-wave"
                            d="M0 10 Q 12.5 0 25 10 T 50 10 T 75 10 T 100 10"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="6"
                            stroke-linecap="round"></path>
                    </svg>

                    <style>
                        .animate-wave {
                            animation: wave-vibration 3s ease-in-out infinite;
                            /* We use stroke-dasharray to create a sense of movement */
                            stroke-dasharray: 200;
                            stroke-dashoffset: 200;
                            animation:
                                wave-vibration 3s ease-in-out infinite,
                                wave-flow 10s linear infinite;
                        }

                        @keyframes wave-vibration {
                            0%,
                            100% {
                                d: path(
                                    "M0 10 Q 12.5 0 25 10 T 50 10 T 75 10 T 100 10"
                                );
                            }
                            50% {
                                d: path(
                                    "M0 10 Q 12.5 15 25 10 T 50 5 T 75 15 T 100 10"
                                );
                            }
                        }

                        @keyframes wave-flow {
                            from {
                                stroke-dashoffset: 400;
                            }
                            to {
                                stroke-dashoffset: 0;
                            }
                        }
                    </style>

                    <h1
                        class="text-[34px] sm:text-[42px] lg:text-[48px] font-serif text-xiri-navy leading-[1.1] tracking-tight"
                    >
                        Conciergerie Airbnb : <br />
                        <span class="font-light text-xiri-gold"
                            >Gestion complète de vos locations.</span
                        >
                    </h1>
                    <p class="text-[18px] text-xiri-navy/80 font-semibold tracking-wide">
                        Nos Services : Zéro logistique. 100% Sérénité.
                    </p>

                    <p
                        class="text-[15px] text-xiri-navy/70 leading-relaxed max-w-xl font-medium"
                    >
                        Stratégie tarifaire, gestion opérationnelle. Vous ne gérez plus rien.
                    </p>
                </div>

                <!-- Bullet List with Gold Checks -->
                <ul class="space-y-4 list-none p-0">
                    {
                        strongPoints.map((point) => (
                            <li class="flex items-center gap-4 group">
                                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-xiri-gold/10 flex items-center justify-center transition-transform group-hover:scale-110">
                                    <Check
                                        size={14}
                                        className="text-xiri-gold stroke-[3px]"
                                    />
                                </div>
                                <span class="text-[15px] font-semibold text-xiri-navy tracking-wide">
                                    {point}
                                </span>
                            </li>
                        ))
                    }
                </ul>

                <div class="flex flex-col gap-4 pt-4">
                    <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
                        <a
                            href="#contact"
                            class="w-full sm:w-[260px] flex items-center justify-center bg-gradient-to-r from-xiri-gold to-[#D4B475] text-white px-6 py-3.5 text-[10px] uppercase tracking-[0.25em] font-black hover:scale-105 hover:shadow-2xl transition-all duration-300 rounded-2xl no-underline text-center shadow-xl shadow-xiri-gold/30 ring-1 ring-white/30"
                        >
                            Estimer ma rentabilité
                        </a>
                        <a
                            href="#services"
                            class="w-full sm:w-[260px] flex items-center justify-center bg-white text-xiri-navy border border-xiri-navy/10 px-6 py-3.5 text-[10px] uppercase tracking-[0.25em] font-black hover:border-xiri-navy hover:shadow-lg transition-all duration-500 rounded-2xl no-underline text-center"
                        >
                            Explorer nos services
                        </a>
                    </div>
                    <!-- Google Rating Badge -->
                    <div class="flex flex-col gap-1 px-2 mt-1">
                        <div class="flex items-center gap-1">
                            {[...Array(5)].map((_, i) => (
                                <Star
                                    key={i}
                                    size={12}
                                    className="text-[#fbbc04] fill-[#fbbc04]"
                                />
                            ))}
                        </div>
                        <div class="text-[12px] font-bold text-xiri-navy/80 tracking-wide">
                            4.9/5 <span class="font-normal opacity-60 italic">sur Google</span>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="lg:col-span-5 relative h-[300px] sm:h-[400px] lg:h-[480px]"
            >
                <div
                    class="absolute -inset-4 bg-xiri-gold/5 rounded-[40px] -rotate-2"
                >
                </div>
                <HeroSlider client:load />
            </div>
        </div>
    </div>
</section>
