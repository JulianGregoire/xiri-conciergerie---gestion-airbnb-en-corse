---
import { Image } from "astro:assets";
import { Check, Star } from "lucide-react";
import heroImg from "../../assets/images/hero/chambre-apaisante-et-moderne.png";

const strongPoints = [
    "Une vraie équipe locale, toujours joignable",
    "Le ménage fait après chaque séjour",
    "Une visibilité garantie sur les plateformes de location",
];
---

<section
    id="home"
    class="relative pt-24 pb-12 md:pt-32 md:pb-20 lg:pt-40 lg:pb-24 overflow-hidden border-b border-xiri-navy/5"
>
    <div class="max-w-7xl mx-auto px-6">
        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center"
        >
            <div class="lg:col-span-7 space-y-8 z-10">
                <div class="space-y-6">

                    <!-- Design Element: Gold Wave -->
                    <svg
                        class="text-xiri-gold w-20 h-2 opacity-80 overflow-visible"
                        viewBox="0 0 100 20"
                        preserveAspectRatio="none"
                    >
                        <path
                            class="animate-wave"
                            d="M0 10 Q 12.5 0 25 10 T 50 10 T 75 10 T 100 10"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="6"
                            stroke-linecap="round"></path>
                    </svg>

                    <style>
                        .animate-wave {
                            animation: wave-vibration 3s ease-in-out infinite;
                            /* We use stroke-dasharray to create a sense of movement */
                            stroke-dasharray: 200;
                            stroke-dashoffset: 200;
                            animation:
                                wave-vibration 3s ease-in-out infinite,
                                wave-flow 10s linear infinite;
                        }

                        @keyframes wave-vibration {
                            0%,
                            100% {
                                d: path(
                                    "M0 10 Q 12.5 0 25 10 T 50 10 T 75 10 T 100 10"
                                );
                            }
                            50% {
                                d: path(
                                    "M0 10 Q 12.5 15 25 10 T 50 5 T 75 15 T 100 10"
                                );
                            }
                        }

                        @keyframes wave-flow {
                            from {
                                stroke-dashoffset: 400;
                            }
                            to {
                                stroke-dashoffset: 0;
                            }
                        }
                    </style>


                    <h1
                        class="text-[34px] sm:text-[42px] lg:text-[48px] font-serif text-xiri-navy leading-[1.1] tracking-tight"
                    >
                        Confiez votre bien. <br />
                        <span class="font-light text-xiri-gold"
                            >Récupérez vos revenus.</span
                        >
                    </h1>

                    <p
                        class="text-[15px] text-xiri-navy/70 leading-relaxed max-w-xl font-medium"
                    >
                       Nous sommes une conciergerie avec une équipe à taille humaine, installée dans plusieurs régions — toujours quelqu'un près de vous pour échanger et agir.
                    </p>
                </div>

                <!-- Bullet List with Gold Checks -->
                <ul class="space-y-4 list-none p-0">
                    {
                        strongPoints.map((point) => (
                            <li class="flex items-center gap-4 group">
                                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-xiri-gold/10 flex items-center justify-center transition-transform group-hover:scale-110">
                                    <Check
                                        size={14}
                                        className="text-xiri-gold stroke-[3px]"
                                    />
                                </div>
                                <span class="text-[15px] font-semibold text-xiri-navy tracking-wide">
                                    {point}
                                </span>
                            </li>
                        ))
                    }
                </ul>

                <div class="flex flex-col gap-5 pt-4">
                    <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
                        <a
                            href="#contact"
                            class="w-full sm:w-[260px] flex items-center justify-center bg-gradient-to-r from-xiri-gold to-[#D4B475] text-white px-6 py-3.5 text-[10px] uppercase tracking-[0.25em] font-black hover:scale-105 hover:shadow-2xl transition-all duration-300 rounded-2xl no-underline text-center shadow-xl shadow-xiri-gold/30 ring-1 ring-white/30"
                        >
                            Estimer ma rentabilité
                        </a>
                        <a
                            href="#services"
                            class="w-full sm:w-[260px] flex items-center justify-center bg-white text-xiri-navy border border-xiri-navy/10 px-6 py-3.5 text-[10px] uppercase tracking-[0.25em] font-black hover:border-xiri-navy hover:shadow-lg transition-all duration-500 rounded-2xl no-underline text-center"
                        >
                            Explorer nos services
                        </a>
                    </div>

                    <!-- Google Rating Badge — style Avenir -->
                    <div class="flex items-center gap-3">
                        <!-- Avatars superposés + compteur -->
                        <div class="flex items-center">
                            <div class="flex -space-x-2.5">
                                <div class="w-9 h-9 rounded-full border-2 border-white bg-[#E8D5B0] flex items-center justify-center">
                                    <span class="text-[11px] font-bold text-[#8B6914]">ML</span>
                                </div>
                                <div class="w-9 h-9 rounded-full border-2 border-white bg-[#C5D8E8] flex items-center justify-center">
                                    <span class="text-[11px] font-bold text-[#1B4A6B]">TP</span>
                                </div>
                                <div class="w-9 h-9 rounded-full border-2 border-white bg-[#D4E8C5] flex items-center justify-center">
                                    <span class="text-[11px] font-bold text-[#2D6B1B]">SC</span>
                                </div>
                            </div>
                            <div class="w-9 h-9 rounded-full border-2 border-white bg-xiri-navy flex items-center justify-center -ml-2.5">
                                <span class="text-[10px] font-black text-white">+50</span>
                            </div>
                        </div>
                        <!-- Étoiles + note -->
                        <div class="flex items-center gap-1.5">
                            <div class="flex items-center gap-0.5">
                                {[...Array(5)].map((_, i) => (
                                    <Star key={i} size={15} className="text-[#fbbc04] fill-[#fbbc04]" />
                                ))}
                            </div>
                            <span class="text-[14px] font-bold text-xiri-navy">4.9/5 <span class="font-normal text-xiri-navy/60">sur Google</span></span>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="lg:col-span-5 relative h-[300px] sm:h-[400px] lg:h-[480px]"
            >
                <div class="relative h-full w-full flex items-center justify-center">
                    <Image
                        src={heroImg}
                        alt="Chambre apaisante et moderne – Xiri Conciergerie"
                        class="w-full h-full object-contain"
                        loading="eager"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
