---
---

<section class="py-16 md:py-20 lg:py-24 bg-xiri-navy relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute top-0 right-0 w-96 h-96 bg-xiri-gold rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-xiri-gold rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="text-center mb-12 md:mb-16">
            <span class="text-xiri-gold text-[10px] font-bold uppercase tracking-[0.25em] mb-3 block">
                VOTRE PARCOURS
            </span>
            <h2 class="text-[28px] md:text-[36px] font-serif text-white leading-[1.2]">
                Comment ça marche
            </h2>
            <p class="mt-3 text-[14px] text-white/50 font-medium max-w-lg mx-auto">
                Un chemin simple, conçu pour vous faire performer dès le départ.
            </p>
        </div>

        <!-- Steps -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative">
            <!-- Connecting line (desktop) -->
            <div class="hidden md:block absolute top-[52px] left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-gradient-to-r from-xiri-gold/30 via-xiri-gold/60 to-xiri-gold/30 z-0"></div>

            <!-- Step 1 -->
            <div class="relative flex flex-col items-center text-center px-4 md:px-6 pb-10 md:pb-0">
                <!-- Number badge -->
                <div class="relative z-10 w-[52px] h-[52px] rounded-full bg-xiri-gold flex items-center justify-center mb-6 shadow-lg shadow-xiri-gold/30">
                    <span class="text-[18px] font-serif font-bold text-white">1</span>
                </div>

                <div class="bg-white/5 border border-white/10 rounded-[24px] p-6 md:p-8 w-full">
                    <span class="text-xiri-gold text-[9px] font-bold uppercase tracking-[0.2em] mb-3 block">
                        OFFRE ESSENTIELLE
                    </span>
                    <h3 class="text-[18px] md:text-[20px] font-serif text-white leading-snug mb-3">
                        On commence ensemble
                    </h3>
                    <p class="text-[13px] md:text-[14px] text-white/60 leading-relaxed">
                        On gère tout l'opérationnel. Vous encaissez.
                    </p>
                    <div class="mt-4 pt-4 border-t border-white/10">
                        <span class="text-[12px] font-bold text-xiri-gold/80">% de vos revenus</span>
                        <span class="mx-2 text-white/20">·</span>
                        <span class="text-[12px] text-white/40 italic">sans engagement</span>
                    </div>
                </div>

                <!-- Mobile arrow down -->
                <div class="md:hidden flex items-center justify-center my-4 text-xiri-gold/50">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="relative flex flex-col items-center text-center px-4 md:px-6 pb-10 md:pb-0">
                <div class="relative z-10 w-[52px] h-[52px] rounded-full bg-white/10 border border-xiri-gold/40 flex items-center justify-center mb-6">
                    <span class="text-[18px] font-serif font-bold text-xiri-gold">2</span>
                </div>

                <div class="bg-white/5 border border-white/10 rounded-[24px] p-6 md:p-8 w-full">
                    <span class="text-white/40 text-[9px] font-bold uppercase tracking-[0.2em] mb-3 block">
                        SEUIL ATTEINT
                    </span>
                    <h3 class="text-[18px] md:text-[20px] font-serif text-white leading-snug mb-3">
                        Vous performez
                    </h3>
                    <p class="text-[13px] md:text-[14px] text-white/60 leading-relaxed">
                        Dès que votre bien atteint le seuil de revenus défini, vous débloquez l'accès à l'Offre Performance.
                    </p>
                    <div class="mt-4 pt-4 border-t border-white/10 flex items-center justify-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-xiri-gold animate-pulse"></div>
                        <span class="text-[12px] font-bold text-xiri-gold/80">Déblocage automatique</span>
                    </div>
                </div>

                <div class="md:hidden flex items-center justify-center my-4 text-xiri-gold/50">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="relative flex flex-col items-center text-center px-4 md:px-6">
                <div class="relative z-10 w-[52px] h-[52px] rounded-full bg-gradient-to-br from-xiri-gold to-[#D4B475] flex items-center justify-center mb-6 shadow-lg shadow-xiri-gold/40">
                    <span class="text-[18px] font-serif font-bold text-white">3</span>
                </div>

                <div class="bg-gradient-to-b from-xiri-gold/10 to-xiri-gold/5 border border-xiri-gold/30 rounded-[24px] p-6 md:p-8 w-full relative overflow-hidden">
                    <!-- Shine effect -->
                    <div class="absolute -top-4 -right-4 w-24 h-24 bg-xiri-gold/10 rounded-full blur-xl"></div>

                    <span class="text-xiri-gold text-[9px] font-bold uppercase tracking-[0.2em] mb-3 block relative z-10">
                        OFFRE PERFORMANCE
                    </span>
                    <h3 class="text-[18px] md:text-[20px] font-serif text-white leading-snug mb-3 relative z-10">
                        On accélère ensemble
                    </h3>
                    <p class="text-[13px] md:text-[14px] text-white/60 leading-relaxed relative z-10">
                        Drone, site dédié, catalogue, backlinking — on maximise votre visibilité.
                    </p>
                    <div class="mt-4 pt-4 border-t border-xiri-gold/20 relative z-10">
                        <div class="flex flex-col gap-1.5">
                            <div class="flex items-center justify-center gap-2">
                                <span class="text-[12px] font-bold text-white/80">Renouvellement 1 an</span>
                                <span class="text-[11px] font-black text-xiri-gold bg-xiri-gold/15 px-2 py-0.5 rounded-full">OFFERT</span>
                            </div>
                            <div class="text-[11px] text-white/40">ou accès immédiat à <span class="text-white/70 font-bold">990€</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom CTA -->
        <div class="mt-12 flex justify-center">
            <a
                href="#contact"
                class="bg-gradient-to-r from-xiri-gold to-[#D4B475] text-white px-8 py-4 text-[10px] uppercase tracking-[0.25em] font-black hover:scale-105 hover:shadow-2xl transition-all duration-300 rounded-2xl no-underline shadow-xl shadow-xiri-gold/30"
            >
                Démarrer avec l'Offre Essentielle
            </a>
        </div>
    </div>
</section>
