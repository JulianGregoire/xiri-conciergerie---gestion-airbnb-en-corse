---
import { servicesData } from "../data/servicesData";

const services = Object.values(servicesData);

// Icon mapping to SVG components (using strings here for simplicity)
const icons = {
    "01": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
    "02": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    "03": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-key"><path d="m21 2-2 2.27"/><path d="M21 2H9a7 7 0 0 0-3.03 13.31L2 21l3 3 4.58-4.58A7 7 0 1 0 21 2Z"/><path d="M11 7a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z"/></svg>`,
    "04": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.937A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0l1.582 6.135A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0Z"/><path d="M20 3a1 1 0 0 0-1 1l-1 1-1-1a1 1 0 0 0-1-1l1-1 1-1 1 1Z"/><path d="M4 17a1 1 0 0 0-1 1l-1 1-1-1a1 1 0 0 0-1-1l1-1 1-1 1 1Z"/></svg>`,
    "05": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
    "06": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wrench"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
};
---

<section id="services" class="py-10 md:py-14 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10 px-6 lg:px-12">
        <div
            class="mb-10 md:mb-12 flex flex-col md:flex-row md:items-end justify-between gap-5"
        >
            <div class="max-w-3xl">
                <span
                    class="text-xiri-gold text-[11px] font-bold uppercase tracking-[0.25em] mb-3 block"
                    >Services opérés de A à Z</span
                >
                <h2
                    class="text-[30px] md:text-[34px] font-serif text-xiri-navy leading-[1.2]"
                >
                    Une exécution terrain complète, pilotée comme un service
                    pro.
                </h2>
            </div>
            <a
                href="#contact"
                class="bg-xiri-navy text-white px-6 py-3 text-[11px] uppercase tracking-[0.2em] font-extrabold hover:bg-xiri-gold transition-all duration-300 rounded-xl no-underline inline-block"
            >
                Demander un audit
            </a>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5"
        >
            {
                services.map((service) => (
                    <div class="bg-white border border-xiri-navy/10 p-5 md:p-6 h-full flex flex-col rounded-2xl shadow-sm">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 bg-xiri-bg flex items-center justify-center text-xiri-gold flex-shrink-0 rounded-xl">
                                <Fragment set:html={icons[service.id]} />
                            </div>
                            <h3 class="text-[22px] font-serif text-xiri-navy leading-tight">
                                {service.title}
                            </h3>
                        </div>

                        <p class="text-[14px] text-xiri-navy/80 font-medium leading-relaxed mb-4">
                            {service.description}
                        </p>

                        <div class="space-y-2 flex-grow">
                            {service.expertisePoints.map((point) => (
                                <div class="flex items-start gap-2.5">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-xiri-gold flex-shrink-0 mt-0.5"
                                    >
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                    <p class="text-[14px] text-xiri-navy/80 font-medium leading-relaxed">
                                        {point}
                                    </p>
                                </div>
                            ))}
                        </div>

                        <div class="pt-5 mt-auto">
                            <a
                                href={`/services/${Object.keys(servicesData).find((key) => servicesData[key].id === service.id)}`}
                                class="bg-xiri-navy text-white px-6 py-3 text-[11px] uppercase tracking-[0.2em] font-extrabold hover:bg-xiri-gold transition-all w-full rounded-xl no-underline text-center block"
                            >
                                En savoir plus
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
