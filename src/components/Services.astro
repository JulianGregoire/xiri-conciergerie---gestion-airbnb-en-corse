---
import { Image } from "astro:assets";
import { services } from "../data/services";

import img01 from "../images/gestion_annonces_airbnb.png";
import img02 from "../images/selection_des_voyageurs.png";
import img03 from "../images/checkin_checkout.png";
import img04 from "../images/menagee.png";
import img05 from "../images/assurances_cautions.png";
import img06 from "../images/maintenance_assistance.png";

// Icon mapping to SVG components or imported Images
const icons: Record<string, any> = {
    "01": img01,
    "02": img02,
    "03": img03,
    "04": img04,
    "05": img05,
    "06": img06,
};
---

<section id="services" class="py-16 md:py-20 lg:py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10 px-6 lg:px-12">
        <div
            class="mb-8 md:mb-10 flex flex-col md:flex-row md:items-end justify-between gap-5"
        >
            <div class="max-w-3xl">
                <span
                    class="text-xiri-gold text-[10px] font-bold uppercase tracking-[0.25em] mb-2 block"
                    >NOS SERVICES TOUT-COMPRIS</span
                >
                <h2
                    class="text-[26px] md:text-[30px] font-serif text-xiri-navy leading-[1.2]"
                >
                    Nos services : Zéro logistique. <br />100% Sérénité.
                </h2>
            </div>
            <a
                href="#contact"
                class="bg-xiri-navy text-white px-5 py-2.5 text-[10px] uppercase tracking-[0.2em] font-extrabold hover:bg-xiri-gold transition-all duration-300 rounded-xl no-underline inline-block"
            >
                Demander un audit
            </a>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
        >
            {
                Object.entries(services).map(([key, service]) => (
                    <a 
                        href={`/services/${key}`}
                        class="bg-white border border-xiri-navy/10 p-6 md:p-8 h-full flex flex-col items-center text-center rounded-[28px] shadow-sm hover:shadow-xl hover:border-xiri-gold/30 hover:-translate-y-1 transition-all duration-500 no-underline group"
                    >
                        <div class="flex flex-col items-center gap-5 mb-5">
                            <div class="flex items-center justify-center flex-shrink-0 transition-transform duration-500 group-hover:scale-110">
                                {typeof icons[service.id] === 'string' ? (
                                    <div class="w-8 h-8 bg-xiri-bg flex items-center justify-center text-xiri-gold rounded-xl">
                                        <Fragment set:html={icons[service.id]} />
                                    </div>
                                ) : (
                                    <Image 
                                        src={icons[service.id]} 
                                        alt={service.title} 
                                        class={`${
                                            service.id === '01' ? 'w-16 h-16 sm:w-20 sm:h-20' : 
                                            service.id === '06' ? 'w-14 h-14 sm:w-16 sm:h-16' : 
                                            'w-16 h-16 sm:w-16 sm:h-16'
                                        } object-contain`} 
                                    />
                                )}
                            </div>
                            <h3 class="text-xl md:text-2xl font-serif text-xiri-navy leading-tight group-hover:text-xiri-gold transition-colors duration-300">
                                {service.title}
                            </h3>
                        </div>

                        <p class="text-[14px] md:text-[15px] text-xiri-navy/70 font-medium leading-relaxed max-w-[280px] mb-6">
                            {service.description}
                        </p>

                        <div class="mt-auto pt-6 border-t border-xiri-navy/5 w-full flex items-center justify-center gap-3">
                            <div class="w-1.5 h-1.5 rounded-full bg-xiri-gold animate-pulse"></div>
                            <span class="text-[11px] font-black uppercase tracking-[0.2em] text-xiri-gold">
                                {service.benefit}
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
