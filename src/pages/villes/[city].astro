---
import Layout from "../../layouts/Layout.astro";
import { localSeoData } from "../../data/localSeoData";
import {
    MapPin,
    ShieldCheck,
    TrendingUp,
    Star,
    Check,
    ArrowLeft
} from "lucide-react";

export function getStaticPaths() {
    return Object.keys(localSeoData).map((city) => ({
        params: { city },
        props: { data: localSeoData[city] },
    }));
}

const { data } = Astro.props;

const strongPoints = [
    "Gestion 100% déléguée & sereine",
    "Tarification algorithmique dynamique",
    "Maintenance & Entretien d'excellence",
    "Visibilité financière en temps réel",
];
---

<Layout title={data.metaTitle} description={data.metaDesc}>
    <div class="min-h-screen bg-[#FDFDFD]">
        <!-- Back Button -->
        <div class="fixed top-24 left-6 lg:left-12 z-50">
            <a
                href="javascript:history.back()"
                class="group flex items-center gap-4 text-[9px] uppercase tracking-[0.4em] font-bold text-xiri-navy bg-white/80 backdrop-blur-md px-6 py-4 shadow-sm border border-xiri-navy/5 hover:bg-xiri-navy hover:text-white transition-all no-underline"
            >
                <ArrowLeft
                    size={14}
                    class="group-hover:-translate-x-1 transition-transform"
                />
                Retour
            </a>
        </div>

        <!-- Hero Section : Split Paradigm -->
        <section class="relative min-h-screen flex flex-col lg:flex-row">
            <div
                class="w-full lg:w-1/2 h-[60vh] lg:h-screen sticky top-0 overflow-hidden"
            >
                <img
                    src={data.heroImg}
                    alt={data.name}
                    class="w-full h-full object-cover animate-slow-zoom"
                />
                <div class="absolute inset-0 bg-xiri-navy/10"></div>
            </div>

            <div
                class="w-full lg:w-1/2 flex items-center justify-center p-8 lg:p-24 bg-white"
            >
                <div class="max-w-xl space-y-12">
                    <div class="space-y-6">
                        <span class="text-xiri-gold text-[10px] uppercase tracking-[0.6em] font-black block">CONCIERGERIE DE PROXIMITÉ</span>
                        <h1
                            class="text-[42px] md:text-[56px] lg:text-[68px] font-serif leading-[1.1] text-xiri-navy"
                        >
                            {data.name} : <br />
                            <span class="font-light italic text-xiri-gold">L'Excellence Locative.</span>
                        </h1>
                        <p class="text-[17px] text-xiri-navy/70 leading-relaxed font-medium">
                            {data.intro}
                        </p>
                    </div>

                    <ul class="space-y-4 list-none p-0">
                        {
                            strongPoints.map((point) => (
                                <li class="flex items-center gap-4 group">
                                    <div class="flex-shrink-0 w-6 h-6 rounded-full bg-xiri-gold/10 flex items-center justify-center transition-transform group-hover:scale-110">
                                        <Check
                                            size={14}
                                            className="text-xiri-gold stroke-[3px]"
                                        />
                                    </div>
                                    <span class="text-[14px] font-semibold text-xiri-navy tracking-wide">
                                        {point}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>

                    <div class="pt-8">
                        <a
                            href="#expertise"
                            class="flex items-center gap-4 text-[10px] uppercase tracking-[0.5em] font-black text-[#000000] no-underline group hover:text-xiri-gold transition-colors"
                        >
                            <div class="w-12 h-[1px] bg-xiri-gold group-hover:w-16 transition-all"></div>
                            Explorer l'expertise local
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Local Expertise Section -->
        <section id="expertise" class="py-32 lg:py-56 relative bg-white overflow-hidden">
            <div class="max-w-7xl mx-auto px-6 lg:px-12">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
                    <div class="lg:col-span-8 space-y-16">
                        <div class="space-y-8">
                            <span class="text-xiri-gold text-[10px] font-black uppercase tracking-[0.4em]">Expertise Terrain</span>
                            <h2 class="text-3xl md:text-5xl font-serif text-xiri-navy leading-tight max-w-lg">
                                Une présence <span class="font-light italic">réelle</span> pour votre sérénité.
                            </h2>
                            <p class="text-[18px] text-xiri-navy/80 leading-loose font-medium border-l-2 border-xiri-gold pl-8">
                                {data.localExpertise}
                            </p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-8">
                            <div class="space-y-4 p-8 bg-[#F8FAFC] rounded-2xl border border-xiri-navy/5">
                                <ShieldCheck className="text-xiri-gold w-10 h-10" />
                                <h4 class="text-[12px] font-black uppercase tracking-widest text-xiri-navy">Conformité Totale</h4>
                                <p class="text-sm text-xiri-navy/60 leading-relaxed">
                                    Nous gérons les déclarations en mairie et la taxe de séjour pour vous, garantissant une exploitation 100% sereine.
                                </p>
                            </div>
                            <div class="space-y-4 p-8 bg-[#F8FAFC] rounded-2xl border border-xiri-navy/5">
                                <TrendingUp className="text-xiri-gold w-10 h-10" />
                                <h4 class="text-[12px] font-black uppercase tracking-widest text-xiri-navy">Rendement Maximal</h4>
                                <p class="text-sm text-xiri-navy/60 leading-relaxed">
                                    Optimisation des prix en temps réel selon la demande locale et les événements saisonniers à {data.name}.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-4">
                        <div class="sticky top-40 space-y-12">
                            <div class="aspect-[4/5] overflow-hidden p-[10px] bg-white shadow-2xl skew-y-1 rotate-2 hover:rotate-0 transition-transform duration-700">
                                <img
                                    src={data.heroImg}
                                    alt="Expertise locale"
                                    class="w-full h-full object-cover"
                                />
                            </div>
                            <div class="space-y-6">
                                <h3 class="text-[10px] uppercase tracking-[0.5em] font-bold text-xiri-gold uppercase">Secteurs Gérés</h3>
                                <div class="flex flex-wrap gap-2">
                                    {data.neighborhoods.map(area => (
                                        <span class="px-3 py-2 bg-xiri-navy/5 rounded-lg text-[10px] font-bold text-xiri-navy/60 uppercase tracking-widest">{area}</span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-40 bg-[#F8FAFC]">
            <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
                <div class="w-20 h-20 bg-xiri-gold/10 rounded-full flex items-center justify-center mx-auto mb-8">
                    <Star className="text-xiri-gold w-8 h-8" />
                </div>
                <h2 class="text-5xl md:text-7xl font-serif text-xiri-navy leading-tight">
                    Votre succès à <br /><span class="font-light text-xiri-gold italic">{data.name}</span> commence ici.
                </h2>
                <div class="pt-8">
                    <a
                        href="/#contact"
                        class="bg-xiri-navy text-white px-16 py-7 text-[11px] uppercase tracking-[0.4em] font-bold hover:bg-black transition-all shadow-2xl hover:-translate-y-1 no-underline inline-block"
                    >
                        Estimer mon bien
                    </a>
                </div>
            </div>
        </section>

        <div class="py-12 border-t border-xiri-navy/5 text-center">
            <span class="text-[9px] uppercase tracking-[1em] text-xiri-navy/20">XIRI CONCIERGE • {data.name.toUpperCase()}</span>
        </div>
    </div>
</Layout>

<style>
    @keyframes slow-zoom {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
    }
    .animate-slow-zoom {
        animation: slow-zoom 20s ease-in-out infinite;
    }
</style>

<style>
    @keyframes slow-zoom {
        0% {
            transform: scale(1.1);
        }
        50% {
            transform: scale(1.2);
        }
        100% {
            transform: scale(1.1);
        }
    }
    .animate-slow-zoom {
        animation: slow-zoom 30s ease-in-out infinite;
    }
</style>

