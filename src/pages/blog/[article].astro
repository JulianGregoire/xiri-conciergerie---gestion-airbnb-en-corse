---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { ArrowLeft, Clock, Facebook, Twitter, Linkedin } from "lucide-react";

export async function getStaticPaths() {
    const entries = await getCollection("blog", ({ data }) => !data.draft);
    return entries.map((entry) => ({
        params: { article: entry.id },
        props: { article: entry.data },
    }));
}

const { article } = Astro.props;
// Normalize intro/sections to always be arrays for the template
const intro = article.intro ?? [];
const sections = article.sections ?? [];
---

<Layout title={`${article.title} | Blog Xiri Conciergerie`} description={article.excerpt} navLight={true}>
    <div class="min-h-screen bg-white">
        <!-- Scroll Progress Bar -->
        <div
            id="progress-bar"
            class="fixed top-0 left-0 w-0 h-1 z-[60] bg-xiri-gold transition-all duration-300"
        >
        </div>

        <div class="fixed top-24 left-6 lg:left-12 z-50">
            <a
                href="/blog"
                class="group flex items-center gap-4 text-[9px] uppercase tracking-[0.4em] font-bold text-xiri-navy bg-white/80 backdrop-blur-md px-6 py-4 shadow-sm border border-xiri-navy/5 hover:bg-xiri-navy hover:text-white transition-all no-underline"
            >
                <ArrowLeft
                    size={14}
                    class="group-hover:-translate-x-1 transition-transform"
                />
                Retour
            </a>
        </div>

        <header
            class="relative h-[80vh] w-full flex items-center justify-center overflow-hidden"
        >
            {typeof article.heroImage === 'string' ? (
                <img
                    src={article.heroImage}
                    class="absolute inset-0 w-full h-full object-cover animate-slow-zoom"
                    alt={article.title}
                />
            ) : (
                <Image
                    src={article.heroImage}
                    alt={article.title}
                    class="absolute inset-0 w-full h-full object-cover animate-slow-zoom"
                />
            )}
            <div class="absolute inset-0 bg-black/30"></div>
            <div
                class="relative z-10 max-w-5xl mx-auto px-6 text-center text-white"
            >
                <div class="space-y-6">
                    <span class="text-xiri-gold text-[10px] md:text-[11px] uppercase tracking-[0.5em] font-extrabold block mb-6 drop-shadow-sm">
                        Expertise & Gestion France
                    </span>
                    <h1
                        class="text-4xl md:text-6xl font-serif leading-[1.15] drop-shadow-2xl"
                    >
                        {article.title}
                    </h1>
                    <div
                        class="flex items-center justify-center gap-6 text-[10px] uppercase tracking-[0.3em] font-black text-white"
                    >
                        <span class="flex items-center gap-2">
                            <Clock size={14} class="text-xiri-gold" />
                            {article.readTime} Lecture
                        </span>
                        <span class="w-1 h-1 bg-xiri-gold rounded-full"></span>
                        <span>{article.date}</span>
                    </div>
                </div>
            </div>
        </header>

        <article class="py-32 lg:py-48 max-w-6xl mx-auto px-6">
            <div class="space-y-16">
                <div
                    class="flex flex-col md:flex-row gap-12 items-start border-b border-xiri-navy/5 pb-16"
                >
                    <div class="md:w-1/3">
                        <div class="sticky top-40 space-y-6">
                            <p
                                class="text-[10px] uppercase tracking-[0.4em] font-black text-[#000000]"
                            >
                                Écrit par
                            </p>
                            <div class="space-y-2">
                                <p class="text-lg font-serif text-xiri-navy">
                                    {article.author}
                                </p>
                                <p
                                    class="text-[10px] uppercase tracking-widest text-xiri-gold font-black"
                                >
                                    Expertise Corse
                                </p>
                            </div>

                            <div class="pt-8 flex gap-4 text-xiri-navy/20">
                                <Facebook
                                    size={18}
                                    class="hover:text-xiri-navy cursor-pointer transition-colors"
                                />
                                <Twitter
                                    size={18}
                                    class="hover:text-xiri-navy cursor-pointer transition-colors"
                                />
                                <Linkedin
                                    size={18}
                                    class="hover:text-xiri-navy cursor-pointer transition-colors"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="md:w-2/3">
                        <p
                            class="text-2xl md:text-3xl font-serif text-[#000000] leading-relaxed mb-12 font-semibold"
                        >
                            "{article.excerpt}"
                        </p>

                        <div
                            class="space-y-8 text-lg md:text-xl text-[#000000] leading-loose font-medium"
                        >
                            {
                                intro.length > 0 && (
                                    <div class="space-y-8">
                                        {intro.map((paragraph, idx) => (
                                            <p
                                                class={
                                                    idx === 0
                                                        ? "first-letter:text-7xl first-letter:font-serif first-letter:float-left first-letter:mr-4 first-letter:text-xiri-gold first-letter:mt-2"
                                                        : ""
                                                }
                                            >
                                                {paragraph}
                                            </p>
                                        ))}
                                    </div>
                                )
                            }

                        </div>
                    </div>
                </div>

                <div class="border-t border-xiri-navy/5 pt-16">
                    {
                        sections.length > 0 && (
                            <div class="space-y-32">
                                {sections.map((section) => (
                                    <div class="space-y-10 animate-fade-in-up max-w-5xl">
                                        <h2 class="text-2xl md:text-3xl font-serif text-xiri-navy border-l-8 border-xiri-gold pl-8 py-2 mb-12">
                                            {section.title}
                                        </h2>
                                        <div class="space-y-6 text-base md:text-lg text-[#000000] leading-relaxed font-medium">
                                            {section.paragraphs.map((p) => (
                                                <p class="max-w-4xl">{p}</p>
                                            ))}
                                        </div>
                                        {section.images && section.images.length > 0 && (
                                            <div class={`grid gap-6 mt-10 ${section.images.length === 1 ? 'grid-cols-1' : 'grid-cols-2'}`}>
                                                {section.images.map((img: any, i: number) => (
                                                    <button type="button" class="zoomable-image group aspect-[4/3] rounded-2xl overflow-hidden relative cursor-zoom-in p-0 border-0 bg-transparent">
                                                        <Image src={img} alt={`${section.title} – photo ${i + 1}`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                                        <span class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                                                            <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-white/90 backdrop-blur-sm rounded-full w-12 h-12 flex items-center justify-center shadow-lg">
                                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-xiri-navy">
                                                                    <circle cx="11" cy="11" r="8"></circle>
                                                                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                                                    <line x1="11" y1="8" x2="11" y2="14"></line>
                                                                    <line x1="8" y1="11" x2="14" y2="11"></line>
                                                                </svg>
                                                            </span>
                                                        </span>
                                                    </button>
                                                ))}
                                            </div>
                                        )}
                                    </div>
                                ))}
                            </div>
                        )
                    }
                </div>

                <div
                    class="bg-xiri-navy p-12 lg:p-20 text-center space-y-8 relative overflow-hidden group rounded-3xl text-white"
                >
                    <div
                        class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-32 -translate-y-32 group-hover:scale-110 transition-transform duration-1000"
                    >
                    </div>
                    <span
                        class="text-xiri-gold text-[10px] font-bold uppercase tracking-[0.6em] relative z-10"
                        >Aller plus loin</span
                    >
                    <h3 class="text-3xl md:text-5xl font-serif relative z-10">
                        Prêt à optimiser la <span class="">gestion</span> de votre
                        bien ?
                    </h3>
                    <a
                        href="/#contact"
                        class="relative z-10 inline-block bg-white text-xiri-navy px-12 py-6 text-[10px] uppercase tracking-[0.4em] font-bold hover:bg-xiri-gold hover:text-white transition-all shadow-xl no-underline rounded-xl"
                    >
                        Consultation Gratuite
                    </a>
                </div>
            </div>
        </article>

        <footer class="py-24 border-t border-xiri-navy/5 text-center">
            <a
                href="/blog"
                class="text-[10px] uppercase tracking-[0.5em] font-black text-[#000000] hover:text-xiri-gold transition-colors no-underline"
            >
                Retour au Blog
            </a>
        </footer>

        <!-- Lightbox -->
        <div
            id="image-lightbox"
            class="fixed inset-0 z-[100] bg-black/90 backdrop-blur-md hidden items-center justify-center p-6 md:p-12 cursor-zoom-out"
            role="dialog"
            aria-modal="true"
            aria-hidden="true"
        >
            <button
                type="button"
                id="lightbox-close"
                aria-label="Fermer"
                class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-sm flex items-center justify-center text-white transition-colors border-0 cursor-pointer"
            >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <img
                id="lightbox-image"
                src=""
                alt=""
                class="max-w-full max-h-full object-contain rounded-lg shadow-2xl"
            />
        </div>
    </div>
</Layout>

<script>
    // Scroll progress bar
    window.addEventListener("scroll", () => {
        const progressBar = document.getElementById("progress-bar");
        if (progressBar) {
            const totalHeight =
                document.documentElement.scrollHeight - window.innerHeight;
            const progress = (window.scrollY / totalHeight) * 100;
            progressBar.style.width = `${progress}%`;
        }
    });

    // Image lightbox
    const lightbox = document.getElementById("image-lightbox");
    const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
    const lightboxClose = document.getElementById("lightbox-close");
    const zoomableImages = document.querySelectorAll<HTMLButtonElement>(".zoomable-image");

    function openLightbox(src: string, alt: string) {
        if (!lightbox || !lightboxImage) return;
        lightboxImage.src = src;
        lightboxImage.alt = alt;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        lightbox.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
        if (!lightbox || !lightboxImage) return;
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImage.src = "";
        document.body.style.overflow = "";
    }

    zoomableImages.forEach((btn) => {
        btn.addEventListener("click", () => {
            const img = btn.querySelector("img");
            if (!img) return;
            // Use the largest available source for full-quality zoom
            const src = img.currentSrc || img.src;
            openLightbox(src, img.alt || "");
        });
    });

    if (lightbox) {
        lightbox.addEventListener("click", (e) => {
            // Close when clicking outside the image (i.e. on the dim backdrop)
            if (e.target === lightbox) closeLightbox();
        });
    }

    if (lightboxClose) {
        lightboxClose.addEventListener("click", (e) => {
            e.stopPropagation();
            closeLightbox();
        });
    }

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
            closeLightbox();
        }
    });
</script>

<style>
    @keyframes slow-zoom {
        0% {
            transform: scale(1);
        }
        100% {
            transform: scale(1.2);
        }
    }
    .animate-slow-zoom {
        animation: slow-zoom 30s linear infinite;
    }
</style>
