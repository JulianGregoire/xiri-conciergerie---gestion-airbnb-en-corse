---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import Reassurance from "../components/sections/Reassurance.astro";
import Services from "../components/sections/Services.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import Ecosystem from "../components/sections/Ecosystem.astro";
import Pricing from "../components/sections/Pricing.astro";
import Parcours from "../components/sections/Parcours.astro";
import CalendlyEmbed from "../components/ui/interactive/CalendlyEmbed";
import Testimonials from "../components/ui/interactive/Testimonials";
import FAQ from "../components/ui/interactive/FAQ";
import Contact from "../components/ui/interactive/Contact";
import RelatedSites from "../components/sections/RelatedSites.astro";
import RegionAccordion from "../components/sections/RegionAccordion.astro";
import OperationalSetup from "../components/sections/OperationalSetup.astro";

// Define the title and description for SEO
const title = "Conciergerie Airbnb Corse, Hérault, Finistère & Savoie | Xiri Conciergerie";
const description =
  "Conciergerie Airbnb premium en Corse, Hérault, Finistère Sud et Savoie. Gestion complète de vos locations saisonnières : marketing, ménage 5★, yield management. Commission dès 12%.";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Est-ce légal de louer sur Airbnb avec Xiri Conciergerie ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Nous gérons toutes les démarches : déclaration en mairie, numéro d'enregistrement, taxe de séjour. Statut LMNP mis en place si souhaité."
      }
    },
    {
      "@type": "Question",
      "name": "Qui encaisse l'argent des locations ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vous. Les paiements arrivent directement sur votre compte (Stripe perso pour les réservations directes, Airbnb pour les plateformes). Xiri prélève sa commission après coup."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de jours puis-je louer mon bien ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour une résidence secondaire, aucune limite. Vous pouvez maximiser toute l'année, haute saison comme basse saison."
      }
    },
    {
      "@type": "Question",
      "name": "Qui paie en cas de casse ou dégradation ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Caution sécurisée (Swikly / Stripe) pour chaque séjour. En cas de dégradation, nous gérons le dossier et activons les assurances (AirCover ou privée)."
      }
    },
    {
      "@type": "Question",
      "name": "Comment sont sélectionnés les voyageurs ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vérification d'identité, historique Airbnb, motif du séjour. Aucun profil douteux ne passe. Votre bien mérite mieux."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je bloquer des dates pour usage personnel ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Via votre espace propriétaire, vous bloquez les dates que vous souhaitez en temps réel. Votre bien reste le vôtre."
      }
    }
  ]
});
---

<Layout title={title} description={description} schema={faqSchema}>
  <main class="space-y-12 lg:space-y-16 xl:space-y-20">
    <Hero />
    <Reassurance />
    <Services />
    <RegionAccordion />
    <HowItWorks />

    <section id="simulator">
      <CalendlyEmbed client:visible />
    </section>

    <OperationalSetup />
    <Parcours />

    <Pricing />
    <Testimonials client:visible />
    <FAQ client:visible />
    
    <section id="contact">
      <Contact client:visible />
    </section>

    <Ecosystem />
    <RelatedSites />

  </main>
</Layout>
