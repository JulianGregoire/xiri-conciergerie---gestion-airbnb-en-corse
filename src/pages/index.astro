---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Ecosystem from "../components/Ecosystem.astro";
import Pricing from "../components/Pricing.astro";
import AISimulator from "../components/AISimulator";
import Testimonials from "../components/Testimonials";
import FAQ from "../components/FAQ";
import Contact from "../components/Contact";
import RelatedSites from "../components/RelatedSites.astro";
import OperationalSetup from "../components/OperationalSetup.astro";

// Define the title and description for SEO
const title = "Xiri Conciergerie | L'Art de Vivre - Gestion Locative Premium";
const description =
  "Xiri Conciergerie : Gestion complète de vos locations saisonnières. Optimisation des revenus, ménage, maintenance et accueil premium.";
---

<Layout title={title} description={description}>
  <main>
    <Hero />
    <Services />
    <Testimonials client:visible />
    <HowItWorks />
    <Ecosystem />
    <Pricing />
    <OperationalSetup />
    <section id="simulator">
      <AISimulator client:visible />
    </section>
    <FAQ client:visible />
    <section id="contact">
      <Contact client:visible />
    </section>
    <RelatedSites />

    <!-- Mobile Sticky CTA -->
    <a
      href="#contact"
      class="fixed bottom-4 left-4 right-4 z-40 lg:hidden bg-xiri-navy text-white py-4 text-[11px] uppercase tracking-[0.14em] font-bold shadow-xl rounded-xl no-underline text-center"
    >
      Estimer ma rentabilité
    </a>
  </main>
</Layout>
