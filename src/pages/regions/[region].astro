---
import Layout from '../../layouts/Layout.astro';
import { regions } from '../../data/regionsData';
import { Minus, ArrowLeft } from "lucide-react";
import Contact from '../../components/Contact';

export function getStaticPaths() {
  return regions.map((region) => ({
    params: { region: region.slug },
    props: { region },
  }));
}

const { region } = Astro.props;

// Meta tags
const title = `${region.name} | Xiri Conciergerie Premium`;
const description = region.description;
---

<Layout title={title} description={description}>
    <div class="min-h-screen bg-[#FDFDFD]">
        <!-- Back Button -->
        <div class="fixed top-24 left-6 lg:left-12 z-50">
            <a
                href="/"
                class="group flex items-center gap-4 text-[9px] uppercase tracking-[0.4em] font-bold text-xiri-navy bg-white/80 backdrop-blur-md px-6 py-4 shadow-sm border border-xiri-navy/5 hover:bg-xiri-navy hover:text-white transition-all no-underline"
            >
                <ArrowLeft
                    size={14}
                    class="group-hover:-translate-x-1 transition-transform"
                />
                Retour
            </a>
        </div>

        <!-- Hero Section : Split Paradigm -->
        <section class="relative min-h-screen flex flex-col lg:flex-row">
            <div
                class="w-full lg:w-1/2 h-[60vh] lg:h-screen sticky top-0 overflow-hidden"
            >
                <img
                    src={region.image.src}
                    alt={region.name}
                    class="w-full h-full object-cover animate-slow-zoom"
                />
                <div class="absolute inset-0 bg-xiri-navy/10"></div>
            </div>

            <div
                class="w-full lg:w-1/2 flex items-center justify-center p-8 lg:p-24 bg-white"
            >
                <div class="max-w-xl space-y-12">
                    <div class="space-y-4">
                        <span class="text-xiri-gold text-[10px] uppercase tracking-[0.6em] font-black block">NOTRE RÉSEAU EXCLUSIF</span>
                        <h1
                            class="text-5xl md:text-7xl font-serif leading-[1.1] text-xiri-navy"
                        >
                            {
                                region.name
                                    .split(" ")
                                    .map((word, i) => (
                                        <span
                                            class={
                                                i < 2 ? "" : "font-light italic text-xiri-gold"
                                            }
                                        >
                                            {word}{" "}
                                        </span>
                                    ))
                            }
                        </h1>
                    </div>

                    <p
                        class="text-xl md:text-2xl font-serif text-[#000000] leading-relaxed border-l-2 border-xiri-gold pl-8 font-medium"
                    >
                        {region.description}
                    </p>

                    {/* Metrics in the Hero area */}
                    <div class="grid grid-cols-3 gap-8 pt-8">
                        <div class="space-y-1">
                            <p class="text-2xl font-serif text-xiri-gold">{region.metrics.properties}</p>
                            <p class="text-[9px] text-xiri-navy/40 uppercase tracking-[0.2em] font-bold">Propriétés</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-2xl font-serif text-xiri-gold">{region.metrics.rating}</p>
                            <p class="text-[9px] text-xiri-navy/40 uppercase tracking-[0.2em] font-bold">Avis</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-2xl font-serif text-xiri-gold">{region.metrics.experience}</p>
                            <p class="text-[9px] text-xiri-navy/40 uppercase tracking-[0.2em] font-bold">Expertise</p>
                        </div>
                    </div>

                    <div class="pt-12">
                        <a href="#villes" class="flex items-center gap-4 text-[10px] uppercase tracking-[0.5em] font-black text-[#000000] no-underline group hover:text-xiri-gold transition-colors">
                            <div class="w-12 h-[1px] bg-xiri-gold group-hover:w-16 transition-all"></div>
                            Découvrir nos secteurs
                        </a>
                    </div>
                </div>
            </div>
        </section>

        {/* Cities Section */}
        <section id="villes" class="py-32 lg:py-56 bg-white relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-6 lg:px-12">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
                    <div class="lg:col-span-4 lg:pt-32">
                        <div class="sticky top-40 space-y-16">
                            <div class="space-y-8">
                                <span class="text-xiri-gold text-[10px] font-bold uppercase tracking-[0.6em] block">Secteurs Gérés</span>
                                <h2 class="text-3xl md:text-5xl font-serif text-xiri-navy leading-tight">
                                    Une présence <span class="font-light italic">locale</span> & réactive.
                                </h2>
                                <p class="text-[17px] text-[#000000] leading-relaxed font-medium">
                                    Nous sélectionnons rigoureusement les secteurs où nous opérons afin de garantir une proximité exemplaire pour nos propriétaires et voyageurs.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-8">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-12">
                            {region.villes.map((ville) => (
                                <a 
                                    href={ville.href}
                                    class="group block bg-[#F8FAFC] border border-xiri-navy/5 p-10 rounded-2xl hover:bg-xiri-navy transition-all duration-500 no-underline shadow-sm hover:shadow-xl hover:-translate-y-1"
                                >
                                    <div class="flex items-center justify-between">
                                        <h3 class="text-2xl font-serif text-xiri-navy group-hover:text-xiri-gold transition-colors duration-500">
                                            {ville.name}
                                        </h3>
                                        <div class="w-10 h-10 rounded-full bg-xiri-navy/5 group-hover:bg-xiri-gold/20 flex items-center justify-center transition-all">
                                            <ArrowLeft size={18} class="text-xiri-navy group-hover:text-xiri-gold transition-colors rotate-180" />
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Contact Section */}
        <section class="py-40 bg-[#F8FAFC]">
            <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
                <span class="text-xiri-gold text-[10px] font-bold uppercase tracking-[0.6em] block">Étude de Projet</span>
                <h2 class="text-3xl md:text-5xl font-serif text-xiri-navy leading-tight">
                    Optimisez la rentabilité de votre bien en <span class="font-light text-xiri-gold italic">{region.slug === 'corse' ? 'Corse' : region.name.replace('Conciergerie de ', '').replace('Conciergerie du ', '')}</span>.
                </h2>
                <div class="pt-12">
                    <a
                        href="/#contact"
                        class="inline-block bg-xiri-navy text-white px-16 py-7 text-[11px] uppercase tracking-[0.4em] font-bold hover:bg-black transition-all shadow-2xl hover:-translate-y-1 no-underline"
                    >
                        Confier mon bien
                    </a>
                </div>
            </div>
        </section>

        <div class="py-12 border-t border-xiri-navy/5 text-center">
            <span class="text-[9px] uppercase tracking-[1em] text-xiri-navy/20">XIRI CONCIERGE • {region.name.toUpperCase()}</span>
        </div>
    </div>
</Layout>

<style>
    @keyframes slow-zoom {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
    }
    .animate-slow-zoom {
        animation: slow-zoom 20s ease-in-out infinite;
    }
</style>
