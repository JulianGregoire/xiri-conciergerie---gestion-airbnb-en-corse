---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import FloatingContact from "../components/layout/FloatingContact.astro";

interface Props {
    title: string;
    description?: string;
    navLight?: boolean;
    navSolid?: boolean;
    ogImage?: string;
    schema?: string;
}

const {
    title,
    description = "Xiri Conciergerie - Gestion premium de locations saisonnières en France. Optimisez vos revenus locatifs en toute sérénité.",
    navLight = false,
    navSolid = false,
    ogImage = "https://xiri-conciergerie.fr/og-default.jpg",
    schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://xiri-conciergerie.fr");

const organizationSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Xiri Conciergerie",
    "url": "https://xiri-conciergerie.fr",
    "logo": "https://xiri-conciergerie.fr/favicon.svg",
    "description": "Conciergerie Airbnb premium en Corse, Hérault, Finistère Sud et Savoie. Gestion complète de locations saisonnières.",
    "telephone": "+33782312206",
    "email": "xirihouse34@gmail.com",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "9 Impasse Lucie Aubrac",
        "addressLocality": "Nissan-lez-Ensérune",
        "postalCode": "34440",
        "addressCountry": "FR"
    },
    "areaServed": [
        { "@type": "Place", "name": "Corse" },
        { "@type": "Place", "name": "Hérault" },
        { "@type": "Place", "name": "Finistère Sud" },
        { "@type": "Place", "name": "Savoie" }
    ],
    "sameAs": []
});

const breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "https://xiri-conciergerie.fr/"
        }
    ]
});
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL.href} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:locale" content="fr_FR" />
        <meta property="og:site_name" content="Xiri Conciergerie" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <!-- Schema.org -->
        <script type="application/ld+json" set:html={organizationSchema} />
        <script type="application/ld+json" set:html={breadcrumbSchema} />
        {schema && <script type="application/ld+json" set:html={schema} />}

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin="anonymous"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Libre+Baskerville:wght@400;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="text-xiri-navy bg-gradient-to-br from-[#EAF3F8] via-[#FFFFFF] to-[#FAF3E8] min-h-screen">
        <Navbar light={navLight} solid={navSolid} />
        <slot />
        <Footer />
        <FloatingContact />
    </body>
</html>

<style is:global>
    :root {
        --accent: 136, 58, 234;
        --accent-light: 224, 204, 250;
        --accent-dark: 49, 10, 101;
        --accent-gradient: linear-gradient(
            45deg,
            rgb(var(--accent)),
            rgb(var(--accent-light)) 30%,
            white 60%
        );
    }
    html {
        font-family: "Montserrat", system-ui, sans-serif;
        scroll-behavior: smooth;
    }
</style>
